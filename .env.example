# URL base del API (sin barra final). Ejemplo:
# VITE_API_BASE_URL=https://mi-backend.onrender.com
VITE_API_BASE_URL=http://localhost:4000

# Configuración de Supabase para reemplazar el backend/localStorage.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_BUCKET=product-images

# Correos permitidos para el acceso al panel (opcional).
# Si lo dejas vacío, cualquier usuario que entre con Google podrá acceder.
VITE_ADMIN_ALLOWED_EMAILS=
